<view class="container">
  <view class="card">
    <view class="mono">连接：{{connected ? "OK" : "未连接"}} deviceId: {{deviceId || "-"}}</view>
  </view>

  <view class="card">
    <view class="row">
      <button class="btn secondary" bindtap="onChooseFile" disabled="{{busy}}">选择 firmware.bin</button>
      <button class="btn secondary" bindtap="onDownloadUrl" disabled="{{busy || !url}}">从 URL 下载</button>
      <button class="btn" bindtap="onStartOta" disabled="{{busy || !firmwareReady}}">开始 OTA</button>
      <button class="btn secondary" bindtap="onCopyLogs">复制日志</button>
      <button class="btn secondary" bindtap="onClearLogs">清空日志</button>
    </view>
    <view class="mono" style="margin-top:10px;">{{firmwareName}}</view>
    <view class="mono">total: {{total}} bytes</view>
  </view>

  <view class="card">
    <view class="mono">URL</view>
    <input class="input mono" value="{{url}}" bindinput="onUrlInput" placeholder="https://.../firmware.bin" />
  </view>

  <view class="card">
    <view class="mono">进度：{{sent}} / {{total}}（{{percent}}%）</view>
    <progress percent="{{percent}}" stroke-width="6" active="{{busy}}" />
    <view class="mono" style="margin-top:6px;">重试次数：{{retries}}</view>
    <view class="mono" style="margin-top:6px;">状态：{{status}}</view>
  </view>

  <view class="card">
    <view class="mono">{{log}}</view>
  </view>
</view>

