<scroll-view class="pageScroll" scroll-y="{{canScroll}}" enhanced="{{true}}" bounces="{{false}}" show-scrollbar="{{false}}" scroll-with-animation="{{false}}">
<view class="container">
  <view class="card">
    <view class="row">
      <button class="btn secondary" bindtap="onOpenAdapter">打开蓝牙</button>
      <button class="btn secondary" bindtap="onScanConnect">扫描并连接</button>
      <button class="btn" bindtap="onPing" disabled="{{!connected}}">PING</button>
    </view>
    <view class="mono" style="margin-top:10px;">连接：{{connected ? "OK" : "未连接"}} deviceId: {{deviceId || "-"}}</view>
  </view>

  <view class="card">
    <view class="title">槽位</view>
    <view class="slots">
      <view class="slot" wx:for="{{slots}}" wx:key="slot">
        <view class="slotHead">
          <view class="tag">slot{{item.slot}}</view>
          <view class="tag">{{item.status}}</view>
        </view>
        <view class="row">
          <button class="btn secondary" bindtap="onPull" data-slot="{{item.slot}}" disabled="{{!connected}}">拉取预览</button>
          <button class="btn" bindtap="onPush" data-slot="{{item.slot}}" disabled="{{!connected}}">选择并上传</button>
        </view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="title">预览（slot{{previewSlot}}）</view>
    <canvas id="preview" type="2d" style="width:240px;height:240px;border-radius:10px;background:#111;" />
  </view>

  <view class="card">
    <view class="row" style="margin-bottom:10px;">
      <button class="btn secondary" bindtap="onCopyLogs">复制日志</button>
      <button class="btn secondary" bindtap="onClearLogs">清空日志</button>
    </view>
    <view class="mono">{{log}}</view>
  </view>
</view>
</scroll-view>

