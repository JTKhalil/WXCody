.container {
  background: #121214;
  min-height: 100vh;
  padding-bottom: 24px;
}

.nav {
  padding: 18px 12px 10px;
}

.titleBig {
  font-size: 22px;
  font-weight: 800;
  color: #fff;
}

.card {
  background: #1c1c1f;
  border: 1px solid #333;
  border-radius: 14px;
  padding: 12px;
  margin-bottom: 12px;
  margin-left: 12px;
  margin-right: 12px;
}

.row {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  align-items: center;
}

.btn {
  background: #e67e22;
  color: #fff;
  font-size: 14px;
  padding: 10px 12px;
  border-radius: 12px;
}

.btn.secondary {
  background: #2a2a2a;
  color: #eee;
  border: 1px solid rgba(255, 255, 255, 0.12);
}

.btn.danger {
  background: #e74c3c;
}

.tag {
  font-size: 12px;
  color: #ddd;
  background: rgba(255, 255, 255, 0.06);
  padding: 4px 8px;
  border-radius: 999px;
}

.mono {
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
  font-size: 12px;
  color: #cfcfcf;
  white-space: pre-wrap;
  word-break: break-word;
}

.mono.small {
  font-size: 11px;
  color: #999;
  margin-top: 6px;
}

.sectionTitle {
  margin: 10px 16px 8px;
  color: #9aa0a6;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.08em;
}

.title {
  font-size: 14px;
  color: #fff;
  margin-bottom: 10px;
  font-weight: 600;
}

.slots {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.slot {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 12px;
  padding: 10px;
}

.slotHead {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
  align-items: center;
}

.previewCanvas {
  width: 240px;
  height: 240px;
  border-radius: 14px;
  background: #111;
  margin-top: 10px;
}

