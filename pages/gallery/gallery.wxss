.container {
  padding: 14px;
}

.card {
  background: #1a1a1a;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 14px;
  padding: 12px;
  margin-bottom: 12px;
}

.row {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  align-items: center;
}

.btn {
  background: #2d6cff;
  color: #fff;
  font-size: 14px;
  padding: 10px 12px;
  border-radius: 12px;
}

.btn.secondary {
  background: #2a2a2a;
  color: #eee;
  border: 1px solid rgba(255, 255, 255, 0.12);
}

.tag {
  font-size: 12px;
  color: #ddd;
  background: rgba(255, 255, 255, 0.06);
  padding: 4px 8px;
  border-radius: 999px;
}

.mono {
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
  font-size: 12px;
  color: #cfcfcf;
  white-space: pre-wrap;
  word-break: break-word;
}

.title {
  font-size: 14px;
  color: #fff;
  margin-bottom: 10px;
  font-weight: 600;
}

.slots {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.slot {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 12px;
  padding: 10px;
}

.slotHead {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
  align-items: center;
}

