.container {
  background: #121214;
  min-height: 100vh;
  padding-bottom: 12px;
  overflow-x: hidden;
}

.card {
  background: #1c1c1f;
  border: 1px solid #333;
  border-radius: 14px;
  padding: 12px;
  margin-bottom: 12px;
  margin-left: 12px;
  margin-right: 12px;
}

.row {
  display: flex;
  flex-direction: row;
  gap: 8px;
  flex-wrap: wrap;
  align-items: center;
}

.mono {
  font-family: ui-monospace, Menlo, Consolas, monospace;
  color: #ddd;
  font-size: 12px;
  line-height: 1.4;
  white-space: pre-wrap;
  word-break: break-all;
}

.btn {
  background: #e67e22;
  color: #fff;
  border: none;
  border-radius: 10px;
  padding: 10px 12px;
  font-size: 13px;
  font-weight: 600;
}

.btn.secondary { background: #3a3a40; }
.btn::after { border: none; }
button::after { border: none; }
.btn:disabled { opacity: 0.5; }

.btn.hdMainBtn {
  height: 44px;
  padding: 0 14px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hdLabel {
  font-size: 12px;
  font-weight: 700;
  color: #ccc;
  margin-bottom: 8px;
}

.hdGuessPrompt {
  width: 100%;
  text-align: center;
  font-size: 16px;
  font-weight: 700;
  color: #e67e22;
  margin-bottom: 10px;
  letter-spacing: 0.05em;
}

.btn.hdGuessSkipBtn { background: #3498db; }
.btn.hdGuessSkipBtn::after { border: none; }

.hdCanvasWrap {
  position: relative;
  width: 100%;
  max-width: 100%;
  height: auto;
  aspect-ratio: 1 / 1;
  margin: 0 auto 12px;
  border-radius: 0;
  overflow: hidden;
}

.hdCanvas {
  width: 100%;
  height: 100%;
  display: block;
  border: none;
  border-radius: 0;
  background: #000;
  touch-action: none;
  vertical-align: top;
}

.hdPullOverlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  padding: 16px 12px;
  background: rgba(0, 0, 0, 0.75);
  border-radius: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.hdPullTitle {
  color: #eee;
  font-size: 13px;
  font-weight: 600;
  margin-bottom: 14px;
  text-align: center;
}

.hdPullBarTrack {
  width: 200px;
  height: 8px;
  border-radius: 0;
  background: #333;
  overflow: hidden;
  margin-bottom: 10px;
}

.hdPullBarFill {
  height: 100%;
  border-radius: 0;
  background: #e67e22;
  width: 0%;
  transition: width 0.12s ease-out;
}

.hdPullPct {
  color: #aaa;
  font-size: 12px;
  font-family: ui-monospace, Menlo, Consolas, monospace;
}

.hdModeBlockOverlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  padding: 14px 12px;
  background: rgba(18, 18, 20, 0.88);
  border: 1px solid #5d4a32;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 4;
}

.hdModeBlockText {
  color: #f0e6d8;
  font-size: 12px;
  line-height: 1.55;
  text-align: center;
}

.hdClearOverlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  padding: 16px 12px;
  background: rgba(0, 0, 0, 0.78);
  border-radius: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 5;
}

.hdClearOverlay loading {
  color: #eee;
  font-size: 13px;
  font-weight: 600;
}

.hdGuessStartOverlay { z-index: 6; }

.hdSwatch {
  width: 28px;
  height: 28px;
  border-radius: 8px;
  border: 2px solid #444;
  margin-right: 8px;
  margin-bottom: 8px;
  box-sizing: border-box;
}

.hdSwatchOn {
  border-color: #e67e22;
  box-shadow: 0 0 0 2px rgba(230, 126, 34, 0.35);
}

