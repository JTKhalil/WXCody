.container {
  background: #121214;
  min-height: 100vh;
  padding-bottom: 12px;
  overflow-x: hidden;
}

.card {
  background: #1c1c1f;
  border: 1px solid #333;
  border-radius: 14px;
  padding: 12px;
  margin-bottom: 12px;
  margin-left: 12px;
  margin-right: 12px;
}

.row {
  display: flex;
  flex-direction: row;
  gap: 8px;
  flex-wrap: wrap;
  align-items: center;
}

.mono {
  font-family: ui-monospace, Menlo, Consolas, monospace;
  color: #ddd;
  font-size: 12px;
  line-height: 1.4;
  white-space: pre-wrap;
  word-break: break-all;
}

.mono.small {
  font-size: 11px;
  color: #999;
}

.title {
  font-size: 14px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10px;
}

.btn {
  background: #e67e22;
  color: #fff;
  border: none;
  border-radius: 10px;
  padding: 10px 12px;
  font-size: 13px;
  font-weight: 600;
}

.btn.secondary { background: #3a3a40; }
.btn.danger { background: #e74c3c; }
.btn::after { border: none; }
button::after { border: none; }
.btn:disabled { opacity: 0.5; }

.btn.smallBtn {
  padding: 8px 10px;
  font-size: 12px;
  border-radius: 10px;
  line-height: 1;
}

.input {
  width: 100%;
  box-sizing: border-box;
  background: #101012;
  border: 1px solid #333;
  border-radius: 12px;
  padding: 10px 10px;
  color: #eee;
  min-height: 84px;
}

.noteItem {
  background: #2a2a2f;
  border: 1px solid #333;
  border-radius: 12px;
  padding: 10px;
  margin-bottom: 10px;
}

.noteFooter {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
}

.noteActions {
  display: flex;
  gap: 8px;
  align-items: center;
  flex-wrap: wrap;
}

.overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0,0,0,0.65);
  z-index: 1000;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 18px 12px;
  box-sizing: border-box;
}

.overlay.show { display: flex; }

.modal {
  width: 100%;
  max-width: 520px;
  background: #1c1c1f;
  border: 1px solid #333;
  border-radius: 14px;
  padding: 14px;
  box-sizing: border-box;
}

.modalTitle {
  font-size: 14px;
  font-weight: 800;
  color: #fff;
  margin-bottom: 10px;
}

