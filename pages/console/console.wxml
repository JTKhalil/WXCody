<scroll-view class="pageScroll" scroll-y="{{canScroll}}" enhanced="{{true}}" bounces="{{false}}" show-scrollbar="{{false}}" scroll-with-animation="{{false}}">
<view class="container">
  <view wx:if="{{fwBgRunning}}" class="fwTopProgressWrap">
    <view class="fwTopBarTrack">
      <view class="fwTopBarFill" style="width: {{fwBgPercent}}%;" />
    </view>
  </view>
  <!-- Tab: Mode -->
  <view class="card" wx:if="{{activeTab===0}}">
    <view class="title">模式</view>
    <view class="modeGrid">
      <view class="modeRow">
        <view class="modeBtn mode0 {{modeCurrent===0?'on':''}}" bindtap="onSetMode" data-mode="0">🖼️ 图片模式</view>
        <button class="modeSettingsBtn" catchtap="onOpenModeSettings" data-mode="0">⚙️</button>
      </view>
      <view class="modeRow">
        <view class="modeBtn mode1 {{modeCurrent===1?'on':''}}" bindtap="onSetMode" data-mode="1">⏰ 时钟模式</view>
        <button class="modeSettingsBtn" catchtap="onOpenModeSettings" data-mode="1">⚙️</button>
      </view>
      <view class="modeRow">
        <view class="modeBtn mode2 {{modeCurrent===2?'on':''}}" bindtap="onSetMode" data-mode="2">📝 笔记模式</view>
        <button class="modeSettingsBtn" catchtap="onOpenModeSettings" data-mode="2">⚙️</button>
      </view>
      <view class="modeRow">
        <view class="modeBtn mode3 {{modeCurrent===3?'on':''}}" bindtap="onSetMode" data-mode="3">😊 表情模式</view>
        <button class="modeSettingsBtn" catchtap="onOpenModeSettings" data-mode="3">⚙️</button>
      </view>
      <view class="modeRow">
        <view class="modeBtn mode4 {{modeCurrent===4?'on':''}}" bindtap="onSetMode" data-mode="4">✏️ 手绘模式</view>
        <button class="modeSettingsBtn" catchtap="onOpenModeSettings" data-mode="4">⚙️</button>
      </view>
    </view>
  </view>

  <!-- Tab: Gallery -->
  <view class="card galleryFull" hidden="{{activeTab!==1}}">
    <view class="title">图片轮播</view>
    <view class="row" style="justify-content:space-between; align-items:center;">
      <view class="mono">启用轮播</view>
      <switch checked="{{imgSlideshowEnabled}}" bindchange="onImgSlideshowToggle" />
    </view>
    <view class="mono" style="margin-top:10px;">间隔：{{imgInterval}} 秒</view>
    <slider min="3" max="60" value="{{imgInterval}}" step="1" bindchanging="onImgIntervalChanging" bindchange="onImgIntervalChange" />
  </view>

  <view class="card galleryFull" hidden="{{activeTab!==1}}">
    <view class="slots">
      <view class="slot {{item.hasImage ? 'hasImage' : ''}}" wx:for="{{slots}}" wx:key="slot">
        <view class="thumb">
          <canvas id="thumb{{item.slot}}" type="2d" class="thumbCanvas" />
          <view class="thumbMask" wx:if="{{item.busy}}"></view>
          <view class="thumbProgress" wx:if="{{item.busy}}">
            <progress class="pProg" percent="{{item.progressPct}}" stroke-width="6" />
            <view class="pText">{{item.progressPct}}%</view>
            <button class="btn secondary smallBtn cancelBtn" wx:if="{{item.status==='pushing...'}}" catchtap="onCancelUpload" data-slot="{{item.slot}}">取消上传</button>
          </view>
          <view class="thumbHint" wx:elif="{{!item.hasImage}}">请上传图片</view>
          <view class="thumbHint" wx:elif="{{!item.previewReady}}"></view>
          <view class="thumbDel {{uploadLock ? 'disabled' : ''}}" wx:if="{{item.hasImage}}" catchtap="onDeleteImage" data-slot="{{item.slot}}">×</view>
        </view>

        <view class="row" style="margin-top:10px;">
          <button class="btn" catchtap="onPush" data-from="btn" data-slot="{{item.slot}}" disabled="{{!connected || item.busy || (uploadLock && uploadingSlot!==item.slot)}}">
            {{item.hasImage ? "替换" : "上传"}}
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- hidden work canvas: keep old preview while resizing -->
  <canvas id="workCanvas" type="2d" class="workCanvas" />

  <!-- Tab: Notes -->
  <view class="card" wx:if="{{activeTab===2}}">
    <view class="title">笔记轮播</view>
    <view class="row" style="justify-content:space-between; align-items:center;">
      <view class="mono">启用轮播</view>
      <switch checked="{{noteSlideshow}}" bindchange="onNoteSlideshowToggle" />
    </view>
    <view class="mono" style="margin-top:10px;">间隔：{{noteInterval}} 秒</view>
    <slider min="3" max="60" value="{{noteInterval}}" step="1" bindchanging="onNoteIntervalChanging" bindchange="onNoteIntervalChange" />
  </view>

  <view class="card" wx:if="{{activeTab===2}}">
    <view class="title">{{noteEditIndex>=0 ? "编辑笔记" : "新增笔记"}}</view>
    <textarea class="input mono" value="{{noteText}}" maxlength="100" placeholder="输入笔记（最多100字）..." bindinput="onNoteTextInput" />
    <view class="mono small" style="margin-top:6px; text-align:right;">{{noteCharCount}}/100（剩余{{noteCharLeft}}）</view>
    <view class="row" style="margin-top:10px;">
      <button class="btn" bindtap="onSaveNote" disabled="{{!connected}}">{{noteEditIndex>=0 ? "保存" : "添加"}}</button>
    </view>
  </view>

  <view class="card" wx:if="{{activeTab===2}}">
    <view class="title">历史笔记</view>
    <view class="noteItem" wx:for="{{notes}}" wx:key="origIndex">
      <view class="mono" style="margin-bottom:8px; white-space:pre-wrap;">{{item.content}}</view>
      <view class="noteFooter">
        <view class="mono small">{{item.time || ""}}</view>
        <view class="noteActions">
          <button class="btn secondary smallBtn" bindtap="onPinNote" data-idx="{{item.origIndex}}" disabled="{{!connected}}">
            {{notePinnedOrig===item.origIndex ? "取消置顶" : "置顶"}}
          </button>
          <button class="btn secondary smallBtn" bindtap="onEditNote" data-idx="{{item.origIndex}}">编辑</button>
          <button class="btn danger smallBtn" bindtap="onDeleteNote" data-idx="{{item.origIndex}}" disabled="{{!connected}}">删除</button>
        </view>
      </view>
    </view>
  </view>

  <!-- Tab: Handdraw（紧跟笔记；hidden 保留 canvas 节点，避免 wx:if 销毁导致闪断） -->
  <view class="card" hidden="{{activeTab!==3}}">
    <view class="hdLabel">画板（手绘同步存在延迟属于正常现象）</view>
    <view wx:if="{{hdGuessPlaying && hdGuessPrompt}}" class="hdGuessPrompt mono">{{hdGuessPrompt}}</view>
    <view class="hdCanvasWrap">
      <canvas id="canvasDraw" type="2d" class="hdCanvas" bindtouchstart="onHdTouchStart" catchtouchmove="onHdTouchMove" bindtouchend="onHdTouchEnd" bindtouchcancel="onHdTouchEnd" />
      <view wx:if="{{hdPulling}}" class="hdPullOverlay">
        <text class="hdPullTitle">正在从设备同步画稿</text>
        <view class="hdPullBarTrack">
          <view class="hdPullBarFill" style="width: {{hdPullPercent}}%;" />
        </view>
        <text class="hdPullPct">{{hdPullPercent}}%</text>
      </view>
      <view wx:if="{{hdDrawBlocked || hdGuessRevealBlock}}" class="hdModeBlockOverlay" catchtouchmove="noop" catchtouchstart="noop">
        <text class="hdModeBlockText">{{hdGuessRevealBlock ? hdGuessRevealMsg : hdDrawBlockMsg}}</text>
      </view>
      <view wx:if="{{hdClearing}}" class="hdClearOverlay" catchtouchmove="noop" catchtouchstart="noop">
        <loading mode="circular">正在清屏…</loading>
      </view>
      <view wx:if="{{hdGuessStarting}}" class="hdClearOverlay hdGuessStartOverlay" catchtouchmove="noop" catchtouchstart="noop">
        <loading mode="circular">准备游戏中…</loading>
      </view>
    </view>

    <view class="row" style="margin-top:12px; flex-wrap:wrap;">
      <button class="btn secondary hdMainBtn" bindtap="onHdClear" disabled="{{!connected || hdDrawBlocked || hdClearing}}">清屏</button>
    </view>
    <view class="row" style="margin-bottom:8px; flex-wrap:wrap;">
      <view class="mono" style="width:100%;margin-bottom:6px;">画笔颜色</view>
      <view wx:for="{{hdPalette}}" wx:key="*this" class="hdSwatch {{hdPenHex===item?'hdSwatchOn':''}}" style="background:{{item}};" data-hex="{{item}}" bindtap="onHdPickColor" />
    </view>
    <view class="mono" style="margin-top:8px;">画笔粗细：{{hdStrokeW}} px</view>
    <slider min="2" max="16" value="{{hdStrokeW}}" step="2" bindchanging="onHdStrokeChanging" bindchange="onHdStrokeChange" />
    <view class="row" style="justify-content:space-between; align-items:center; margin-top:10px;">
      <view class="mono">镜像模式</view>
      <switch checked="{{hdMirror}}" bindchange="onHdMirrorToggle" />
    </view>
    <view class="row" style="margin-top:12px; flex-wrap:wrap;">
      <button class="btn hdMainBtn" bindtap="onHdGuessGame" disabled="{{!connected || hdDrawBlocked || hdClearing || hdGuessStarting}}">{{hdGuessPlaying ? '结束游戏' : '你画我猜'}}</button>
    </view>
    <view wx:if="{{hdGuessPlaying && hdGuessPrompt}}" class="row" style="margin-top:10px;">
      <button class="btn hdGuessSkipBtn hdMainBtn" bindtap="onHdGuessSkip" disabled="{{!connected || !hdGuessPlaying || hdDrawBlocked || hdClearing || hdGuessStarting}}">跳过</button>
    </view>
  </view>

  <!-- Tab: Settings -->
  <view wx:if="{{activeTab===4}}">
    <!-- 系统设置主列表：仅保留标题按钮 -->
    <view class="card">
      <view class="title">系统设置</view>
      <view class="settingsList">
        <button class="settingsEntry" bindtap="onOpenSystemSettings" data-page="conn">
          <text class="settingsIcon">🔌</text>
          <text class="settingsLabel">连接设置</text>
        </button>
        <button class="settingsEntry" bindtap="onOpenSystemSettings" data-page="fs">
          <text class="settingsIcon">💾</text>
          <text class="settingsLabel">存储空间</text>
        </button>
        <button class="settingsEntry" bindtap="onOpenSystemSettings" data-page="fw">
          <text class="settingsIcon">⬆️</text>
          <text class="settingsLabel">更新设置</text>
        </button>
        <button class="settingsEntry" bindtap="onOpenSystemSettings" data-page="bright">
          <text class="settingsIcon">💡</text>
          <text class="settingsLabel">背光亮度</text>
        </button>
      </view>
    </view>
  </view>

  <!-- Bottom Tabs：手绘在笔记后、设置前 -->
  <view class="tabsBottom">
    <button class="tabBtn {{activeTab===0?'active':''}}" bindtap="onTab" data-tab="0">模式切换</button>
    <button class="tabBtn {{activeTab===4?'active':''}}" bindtap="onTab" data-tab="4">系统设置</button>
  </view>

  <!-- Confirm modal -->
  <view wx:if="{{confirmOpen}}" class="overlay show" catchtap="onCancelConfirm">
    <view class="modal" catchtap="noop">
      <view class="modalTitle">系统提示</view>
      <view class="mono">{{confirmMsg}}</view>
      <view class="row" style="margin-top:12px;">
        <button class="btn secondary" bindtap="onCancelConfirm">取消</button>
        <button class="btn danger" bindtap="onOkConfirm">确定</button>
      </view>
    </view>
  </view>
</view>
</scroll-view>

