<view class="container">
  <view class="navTop">
    <view class="largeTitle">控制台</view>
    <view class="statusRow">
      <view class="pill {{connected ? 'on' : 'off'}}">{{connected ? "已连接" : "未连接"}}</view>
      <view class="mono small statusName">{{codyName || "-"}}</view>
      <view style="flex:1;"></view>
      <button class="ghostBtn" bindtap="onReconnect" disabled="{{connected}}">重连</button>
      <button class="ghostBtn" bindtap="onRefreshMode" disabled="{{!connected}}">刷新</button>
    </view>
    <view wx:if="{{status}}" class="mono small statusLine">{{status}}</view>
  </view>

  <view class="section">
    <view class="sectionTitle">模式</view>
    <view class="card">
      <view class="row" style="justify-content:space-between; align-items:center;">
        <view>
          <view class="cellTitle">当前模式</view>
          <view class="mono small cellSub">mode={{modeCurrent}}</view>
        </view>
        <view class="seg">
          <view class="segBtn {{modeCurrent===0?'on':''}}" bindtap="onSetMode" data-mode="0">图</view>
          <view class="segBtn {{modeCurrent===1?'on':''}}" bindtap="onSetMode" data-mode="1">钟</view>
          <view class="segBtn {{modeCurrent===2?'on':''}}" bindtap="onSetMode" data-mode="2">记</view>
          <view class="segBtn {{modeCurrent===3?'on':''}}" bindtap="onSetMode" data-mode="3">表</view>
          <view class="segBtn {{modeCurrent===4?'on':''}}" bindtap="onSetMode" data-mode="4">绘</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="sectionTitle">快捷操作</view>
    <view class="card">
      <view class="quickGrid">
        <button class="quickBtn" bindtap="onGoHanddraw">手绘</button>
        <button class="quickBtn" bindtap="onGoGallery">图库</button>
        <button class="quickBtn" bindtap="onGoDevice">设备</button>
        <button class="quickBtn" bindtap="onGoLogs">日志</button>
      </view>
      <view class="row" style="margin-top:12px;">
        <button class="btn secondary" bindtap="onHdClear" disabled="{{!connected || hdDrawBlocked || hdClearing}}">清屏</button>
        <button class="btn" bindtap="onHdGuessGame" disabled="{{!connected || hdDrawBlocked || hdClearing || hdGuessStarting}}">{{hdGuessPlaying ? '结束你画我猜' : '开始你画我猜'}}</button>
      </view>
      <view class="mono small" style="margin-top:8px; color:#aaa;">清屏/游戏需要设备处于手绘模式</view>
    </view>
  </view>

  <view class="section">
    <view class="sectionTitle">功能</view>
    <view class="list">
      <view class="cell" bindtap="onGoHanddraw">
        <view class="cellTitle">手绘与游戏</view>
        <view class="cellRight">›</view>
      </view>
      <view class="cell" bindtap="onGoGallery">
        <view class="cellTitle">图库与管理</view>
        <view class="cellRight">›</view>
      </view>
      <view class="cell" bindtap="onGoDevice">
        <view class="cellTitle">设备与显示</view>
        <view class="cellRight">›</view>
      </view>
      <view class="cell" bindtap="onGoLogs">
        <view class="cellTitle">日志与调试</view>
        <view class="cellRight">›</view>
      </view>
    </view>
  </view>

  <!-- Confirm modal -->
  <view wx:if="{{confirmOpen}}" class="overlay show" catchtap="onCancelConfirm">
    <view class="modal" catchtap="noop">
      <view class="modalTitle">系统提示</view>
      <view class="mono">{{confirmMsg}}</view>
      <view class="row" style="margin-top:12px;">
        <button class="btn secondary" bindtap="onCancelConfirm">取消</button>
        <button class="btn danger" bindtap="onOkConfirm">确定</button>
      </view>
    </view>
  </view>
</view>

