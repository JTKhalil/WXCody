.container {
  background: #121214;
  min-height: 100vh;
  padding-bottom: 112px; /* bottom tabs height */
  overflow-x: hidden; /* 禁止左右滑动/横向滚动 */
}

.fwTopProgressWrap {
  position: sticky;
  top: 0;
  z-index: 80;
  margin: 0 0 10px 0;
  padding: 0;
  background: transparent;
  border: 0;
  border-radius: 0;
}

.fwTopBarTrack {
  width: 100%;
  height: 6px;
  background: #333;
}

.fwTopBarFill {
  height: 100%;
  width: 0%;
  background: #e67e22;
  transition: width 0.12s ease-out;
}

.tabsBottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  background: #222;
  border: 1px solid #333;
  border-radius: 0;
  overflow: hidden;
}

.card {
  background: #1c1c1f;
  border: 1px solid #333;
  border-radius: 14px;
  padding: 12px;
  margin-bottom: 12px;
  margin-left: 12px;
  margin-right: 12px;
}

.card.galleryFull {
  margin-left: 0;
  margin-right: 0;
  border-left: 0;
  border-right: 0;
  border-radius: 0;
}

.row {
  display: flex;
  flex-direction: row;
  gap: 8px;
  flex-wrap: wrap;
  align-items: center;
}

.mono {
  font-family: ui-monospace, Menlo, Consolas, monospace;
  color: #ddd;
  font-size: 12px;
  line-height: 1.4;
  white-space: pre-wrap;
  word-break: break-all;
}

.mono.small {
  font-size: 11px;
  color: #999;
}

.tag {
  background: #2a2a2f;
  border: 1px solid #3a3a40;
  color: #bbb;
  padding: 4px 8px;
  border-radius: 999px;
  font-size: 12px;
}

.btn {
  background: #e67e22;
  color: #fff;
  border: none;
  border-radius: 10px;
  padding: 10px 12px;
  font-size: 13px;
  font-weight: 600;
}

.btn.hdMainBtn {
  height: 44px;
  padding: 0 14px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn.secondary {
  background: #3a3a40;
}

.btn.danger {
  background: #e74c3c;
}

.tabBtn {
  flex: 1;
  text-align: center;
  padding: 22px 2px;
  color: #888;
  background: #222;
  border: none;
  border-radius: 0;
  font-size: 14px;
  line-height: 1.15;
}

.tabBtn::after {
  border: none;
}

.tabBtn.active {
  color: #e67e22;
  background: #2a2a2f;
  border-top: 0;
  box-shadow: inset 0 2px 0 #e67e22;
}

.title {
  font-size: 14px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10px;
}

.title.danger {
  color: #e74c3c;
}

.settingsList {
  display: flex;
  flex-direction: column;
  gap: 10px;
  width: 100%;
}

.settingsEntry {
  width: 100% !important;
  align-self: stretch;
  padding: 14px;
  border-radius: 12px;
  background: #2a2a2f;
  border: 2px solid #444;
  color: #eee;
  font-weight: 700;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 10px;
}

.settingsEntry::after { border: none; }

.settingsIcon {
  font-size: 16px;
  line-height: 1;
}

.settingsLabel {
  font-size: 14px;
  font-weight: 800;
  line-height: 1.15;
}

.settingsEntry.danger {
  border-color: #7a3a34;
}

.modeGrid {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.modeRow {
  display: flex;
  flex-direction: row;
  gap: 10px;
  align-items: stretch;
}

.modeBtn {
  flex: 5 1 0;
  padding: 14px;
  border-radius: 12px;
  background: #2a2a2f;
  border: 2px solid #444;
  color: #eee;
  font-weight: 700;
}

.modeSettingsBtn {
  flex: 1 1 0;
  min-width: 0;
  padding: 0 8px;
  border-radius: 12px;
  background: #3a3a40;
  color: #ddd;
  border: 2px solid #444;
  font-size: 16px;
  font-weight: 700;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modeSettingsBtn::after {
  border: none;
}

.modeBtn.on {
  border-color: #e67e22;
}

.modeBtn.mode1.on { border-color: #3498db; }
.modeBtn.mode2.on { border-color: #f1c40f; }
.modeBtn.mode3.on { border-color: #9b59b6; }
.modeBtn.mode4.on { border-color: #2ecc71; }

.hdLabel {
  font-size: 12px;
  font-weight: 700;
  color: #ccc;
  margin-bottom: 8px;
}

.hdGuessPrompt {
  width: 100%;
  text-align: center;
  font-size: 16px;
  font-weight: 700;
  color: #e67e22;
  margin-bottom: 10px;
  letter-spacing: 0.05em;
}

/* 你画我猜：跳过按钮（样式参考主按钮，但用不同颜色） */
.btn.hdGuessSkipBtn {
  background: #3498db;
}

.btn.hdGuessSkipBtn::after { border: none; }

/* 画板与全屏遮罩均为直角，与设备 240×240 像素对齐 */
.hdCanvasWrap {
  position: relative;
  width: 100%;
  max-width: 100%;
  height: auto;
  aspect-ratio: 1 / 1;
  margin: 0 auto 12px;
  border-radius: 0;
  overflow: hidden;
}

.hdCanvas {
  width: 100%;
  height: 100%;
  display: block;
  border: none;
  border-radius: 0;
  background: #000;
  touch-action: none;
  vertical-align: top;
}

.hdPullOverlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  padding: 16px 12px;
  background: rgba(0, 0, 0, 0.75);
  border-radius: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.hdPullTitle {
  color: #eee;
  font-size: 13px;
  font-weight: 600;
  margin-bottom: 14px;
  text-align: center;
}

/* 不用原生 progress：percent 频繁 setData 时组件会反复从 0 重播动画 */
.hdPullBarTrack {
  width: 200px;
  height: 8px;
  border-radius: 0;
  background: #333;
  overflow: hidden;
  margin-bottom: 10px;
}

.hdPullBarFill {
  height: 100%;
  border-radius: 0;
  background: #e67e22;
  width: 0%;
  transition: width 0.12s ease-out;
}

.hdPullPct {
  color: #aaa;
  font-size: 12px;
  font-family: ui-monospace, Menlo, Consolas, monospace;
}

.hdModeBlockOverlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  padding: 14px 12px;
  background: rgba(18, 18, 20, 0.88);
  border: 1px solid #5d4a32;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 4;
}

.hdModeBlockText {
  color: #f0e6d8;
  font-size: 12px;
  line-height: 1.55;
  text-align: center;
}

.hdClearOverlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  padding: 16px 12px;
  background: rgba(0, 0, 0, 0.78);
  border-radius: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 5;
}

.hdClearOverlay loading {
  color: #eee;
  font-size: 13px;
  font-weight: 600;
}

/* 与清屏遮罩同样式，叠在拉取进度之上，避免开始游戏时仍可误触画板 */
.hdGuessStartOverlay {
  z-index: 6;
}

.hdSwatch {
  width: 28px;
  height: 28px;
  border-radius: 8px;
  border: 2px solid #444;
  margin-right: 8px;
  margin-bottom: 8px;
  box-sizing: border-box;
}

.hdSwatchOn {
  border-color: #e67e22;
  box-shadow: 0 0 0 2px rgba(230, 126, 34, 0.35);
}

.slots {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
  padding: 0 8px;
  box-sizing: border-box;
}

.slot {
  background: #2a2a2f;
  border: 1px solid #333;
  border-radius: 12px;
  padding: 10px;
  display: flex;
  flex-direction: column;
  min-width: 0;
  box-sizing: border-box;
}

.slot.hasImage {
  background: #222d28;
}

.slotHead {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
}

.thumb {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 10px;
  background: #111;
  overflow: hidden;
  border: 1px solid #333;
  box-sizing: border-box;
}

.thumbMask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.35);
  z-index: 2;
}

.thumbCanvas {
  width: 100%;
  height: 100%;
}

.workCanvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 240px;
  height: 240px;
  opacity: 0;
  pointer-events: none;
}

.thumbTap {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 2;
}

.thumbHint {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  color: #ddd;
  font-weight: 800;
  padding: 0;
  border-radius: 0;
  border: none;
  background: transparent;
  text-shadow: 0 2px 10px rgba(0,0,0,0.75);
  z-index: 3;
  max-width: 90%;
  text-align: center;
}

.thumbProgress {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  z-index: 3;
  width: 78%;
  background: transparent;
  border: none;
  border-radius: 0;
  padding: 0;
  box-sizing: border-box;
}

.pProg {
  width: 100%;
}

.pText {
  margin-top: 8px;
  text-align: center;
  color: #ddd;
  font-weight: 800;
  font-size: 12px;
  text-shadow: 0 2px 10px rgba(0,0,0,0.75);
}

.cancelBtn {
  margin-top: 10px;
  width: 100%;
}

.thumbDel {
  position: absolute;
  right: 6px;
  top: 6px;
  width: 24px;
  height: 24px;
  line-height: 22px;
  text-align: center;
  padding: 0;
  border-radius: 999px;
  border: 2px solid #1c1c1f;
  background: #e74c3c;
  color: #fff;
  font-weight: 800;
  z-index: 4;
}

.thumbDel::after { border: none; }

.thumbDel.disabled {
  opacity: 0.45;
}

.input {
  width: 100%;
  background: #111;
  border: 1px solid #444;
  color: #fff;
  border-radius: 10px;
  padding: 10px;
  box-sizing: border-box;
}

.noteItem {
  background: #232328;
  border: 1px solid #333;
  border-radius: 12px;
  padding: 10px;
  margin-bottom: 10px;
}

.noteFooter {
  display: flex;
  flex-direction: row;
  gap: 8px;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
}

.noteActions {
  display: flex;
  flex-direction: row;
  gap: 6px;
  flex-wrap: nowrap;
  align-items: center;
  justify-content: flex-end;
  max-width: 100%;
  width: 100%;
}

.btn.smallBtn {
  padding: 8px 6px;
  font-size: 12px;
  border-radius: 10px;
  line-height: 1;
  flex: 1 1 0;
  min-width: 0;
  max-width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0,0,0,0.75);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

.overlay.show {
  display: flex;
}

.modal {
  width: 88%;
  max-width: 340px;
  background: #1c1c1f;
  border: 1px solid #333;
  border-radius: 14px;
  padding: 14px;
}

.modalTitle {
  color: #fff;
  font-weight: 800;
  margin-bottom: 10px;
}

