<view class="container">
  <view class="nav">
    <view class="title">手绘</view>
    <view class="mono small">{{connected ? "已连接" : "未连接"}} · mode={{modeCurrent}}</view>
  </view>

  <view class="hdCanvasWrap">
    <canvas id="canvasDraw" type="2d" class="hdCanvas" bindtouchstart="onHdTouchStart" catchtouchmove="onHdTouchMove" bindtouchend="onHdTouchEnd" bindtouchcancel="onHdTouchEnd" />
    <view wx:if="{{hdPulling}}" class="hdPullOverlay">
      <text class="hdPullTitle">正在从设备同步画稿</text>
      <view class="hdPullBarTrack">
        <view class="hdPullBarFill" style="width: {{hdPullPercent}}%;" />
      </view>
      <text class="hdPullPct">{{hdPullPercent}}%</text>
    </view>
    <view wx:if="{{hdDrawBlocked || hdGuessRevealBlock}}" class="hdModeBlockOverlay" catchtouchmove="noop" catchtouchstart="noop">
      <text class="hdModeBlockText">{{hdGuessRevealBlock ? hdGuessRevealMsg : hdDrawBlockMsg}}</text>
    </view>
    <view wx:if="{{hdClearing}}" class="hdClearOverlay" catchtouchmove="noop" catchtouchstart="noop">
      <loading mode="circular">正在清屏…</loading>
    </view>
    <view wx:if="{{hdGuessStarting}}" class="hdClearOverlay hdGuessStartOverlay" catchtouchmove="noop" catchtouchstart="noop">
      <loading mode="circular">准备游戏中…</loading>
    </view>
  </view>

  <view wx:if="{{hdGuessPlaying && hdGuessPrompt}}" class="guessWord mono">{{hdGuessPrompt}}</view>

  <view class="toolCard">
    <view class="toolTitle">工具</view>
    <view class="row" style="margin-bottom:10px; flex-wrap:wrap;">
      <view class="mono" style="width:100%;margin-bottom:6px;">颜色</view>
      <view wx:for="{{hdPalette}}" wx:key="*this" class="hdSwatch {{hdPenHex===item?'hdSwatchOn':''}}" style="background:{{item}};" data-hex="{{item}}" bindtap="onHdPickColor" />
    </view>
    <view class="mono">粗细：{{hdStrokeW}} px</view>
    <slider min="2" max="16" value="{{hdStrokeW}}" step="2" bindchanging="onHdStrokeChanging" bindchange="onHdStrokeChange" />
    <view class="row" style="margin-top:12px; flex-wrap:wrap;">
      <button class="btn secondary" bindtap="onHdClear" disabled="{{!connected || hdDrawBlocked || hdClearing}}">清屏</button>
      <button class="btn" bindtap="onHdGuessGame" disabled="{{!connected || hdDrawBlocked || hdClearing || hdGuessStarting}}">{{hdGuessPlaying ? '结束你画我猜' : '开始你画我猜'}}</button>
    </view>
  </view>
</view>

