.container {
  background: #121214;
  min-height: 100vh;
  padding-top: 12px;
  padding-bottom: 12px;
}

.card {
  background: #1c1c1f;
  border: 1px solid #333;
  border-radius: 14px;
  padding: 12px;
  margin-bottom: 12px;
  margin-left: 12px;
  margin-right: 12px;
}

.row {
  display: flex;
  flex-direction: row;
  gap: 8px;
  flex-wrap: wrap;
  align-items: center;
}

.mono {
  font-family: ui-monospace, Menlo, Consolas, monospace;
  color: #ddd;
  font-size: 12px;
  line-height: 1.4;
  white-space: pre-wrap;
  word-break: break-all;
}

.title {
  font-size: 14px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10px;
}

.title.danger { color: #e74c3c; }

.btn {
  background: #e67e22;
  color: #fff;
  border: none;
  border-radius: 10px;
  padding: 10px 12px;
  font-size: 13px;
  font-weight: 600;
}

.btn::after { border: none; }

.btn.secondary { background: #3a3a40; }
.btn.danger { background: #e74c3c; }

.input {
  width: 100%;
  background: #111;
  border: 1px solid #444;
  color: #fff;
  border-radius: 10px;
  padding: 10px;
  box-sizing: border-box;
}

