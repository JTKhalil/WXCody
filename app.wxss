page {
  background: #0b0d10;
  color: #e8eef6;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "PingFang SC", "Microsoft YaHei", Arial, sans-serif;
  /* 禁用 iOS 等平台的滚动回弹（下拉/上滑的橡皮筋动画） */
  overscroll-behavior-y: none;
}

.pageScroll {
  height: 100vh;
  /* 页面滚动交给 scroll-view，本身不需要回弹 */
  overscroll-behavior: none;
}

.container {
  padding: 16px;
}

.card {
  background: #11151b;
  border: 1px solid #1e2632;
  border-radius: 12px;
  padding: 12px;
  margin-bottom: 12px;
}

.row {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.btn {
  background: #2a6df4;
  color: #fff;
  padding: 10px 12px;
  border-radius: 10px;
  font-size: 14px;
  line-height: 1;
}

.btn.secondary {
  background: #2b3442;
}

.mono {
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
  font-size: 12px;
  color: #b8c4d6;
  white-space: pre-wrap;
  word-break: break-all;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: 999px;
  background: #1a2230;
  border: 1px solid #263249;
  color: #cfe0ff;
  font-size: 12px;
}

